{
  "name": "architectsofchaos",
  "private": true,
  "version": "0.0.35",
  "type": "module",
  "main": "electron-main.cjs",
  "repository": {
    "type": "git",
    "url": "https://github.com/leco1904/architects-of-chaos.git"
  },
  "scripts": {
    "update-cards": "node updateCards.js",
    "dev": "npm run update-cards && vite --host",
    "build": "npm run update-cards && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "electron .",
    "electron:build": "npm run build && electron-builder",
    "release": "npm version patch && npm run build && electron-builder build --win --publish always"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.3",
    "electron-updater": "^6.8.3",
    "lucide-react": "^1.14.0",
    "peerjs": "^1.5.5",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "vite": "^8.0.10"
  },
  "build": {
    "appId": "com.ghostnode.aoc",
    "productName": "Architects of Chaos",
    "copyright": "Copyright © 2026 Ghost Node",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "leco1904",
      "repo": "architects-of-chaos",
      "vPrefixedTagName": true,
      "releaseType": "release"
    },
    "files": [
      "dist/**/*",
      "electron-main.cjs",
      "preload.cjs"
    ]
  }
}
